[Unit]
Description=RoboWheels drive controller (CRSF, motors, brakes, USB gadget AI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@DEPLOY_USER@
Group=@DEPLOY_USER@
SupplementaryGroups=gpio i2c dialout
WorkingDirectory=@INSTALL_DIR@
ExecStart=@INSTALL_DIR@/.venv/bin/python drive.py
Restart=on-failure
RestartSec=3
# Allow time for USB gadget / serial devices to appear after boot
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
